[
  { "id": "mt_tables_1", "topicId": "math_tables", "examType": "OGE", "text": "На диаграмме показана температура воздуха по дням недели. В какой день недели температура была наибольшей?", "imageUrl": null, "optionIds": ["a","b","c","d"], "optionTexts": ["Понедельник","Среда","Пятница","Суббота"], "correctOptionId": "c", "correctShortAnswer": null, "explanation": "На диаграмме столбец за пятницу самый высокий среди всех дней недели.", "difficulty": 1 },
  { "id": "mt_tables_2", "topicId": "math_tables", "examType": "OGE", "text": "В таблице приведены цены на билеты в кино в будни и выходные. Сколько будет стоить 3 билета в субботу, если один стоит 350 рублей?", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "1050", "explanation": "350 × 3 = 1050 рублей.", "difficulty": 1 },
  { "id": "mt_tables_3", "topicId": "math_tables", "examType": "OGE", "text": "По графику видно, что курс валюты за неделю вырос с 90 до 96 рублей. На сколько рублей вырос курс?", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "6", "explanation": "96 − 90 = 6 рублей.", "difficulty": 1 },

  { "id": "mt_calc_1", "topicId": "math_calc", "examType": "OGE", "text": "Найдите значение выражения (2/5 + 1/10) × 20", "imageUrl": null, "optionIds": ["a","b","c","d"], "optionTexts": ["9","10","11","12"], "correctOptionId": "b", "correctShortAnswer": null, "explanation": "2/5 + 1/10 = 0.5. Далее 0.5 × 20 = 10.", "difficulty": 1 },
  { "id": "mt_calc_2", "topicId": "math_calc", "examType": "OGE", "text": "Вычислите: 3.7 × 10² − 15", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "355", "explanation": "3.7 × 100 = 370. 370 − 15 = 355.", "difficulty": 1 },
  { "id": "mt_calc_3", "topicId": "math_calc", "examType": "OGE", "text": "Найдите значение выражения √49 + √16", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "11", "explanation": "√49 = 7, √16 = 4. 7 + 4 = 11.", "difficulty": 1 },

  { "id": "mt_fractions_1", "topicId": "math_fractions", "examType": "OGE", "text": "Товар стоил 2000 рублей. Цену снизили на 15%. Сколько стал стоить товар?", "imageUrl": null, "optionIds": ["a","b","c","d"], "optionTexts": ["1700 руб.","1800 руб.","1850 руб.","1900 руб."], "correctOptionId": "b", "correctShortAnswer": null, "explanation": "15% от 2000 — это 300 рублей. 2000 − 300 = 1700 рублей.", "difficulty": 1 },
  { "id": "mt_fractions_2", "topicId": "math_fractions", "examType": "OGE", "text": "Найдите число, если 40% этого числа равны 68.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "170", "explanation": "68 / 0.4 = 170.", "difficulty": 2 },
  { "id": "mt_fractions_3", "topicId": "math_fractions", "examType": "OGE", "text": "Смешали 3 кг конфет по 200 руб/кг и 2 кг по 300 руб/кг. Найдите среднюю цену смеси за 1 кг.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "240", "explanation": "(3×200 + 2×300) / 5 = 1200/5 = 240.", "difficulty": 2 },

  { "id": "mt_eq_1", "topicId": "math_eq", "examType": "OGE", "text": "Решите уравнение: 3x − 7 = 2x + 5. Укажите корень.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "12", "explanation": "3x − 2x = 5 + 7 → x = 12.", "difficulty": 1 },
  { "id": "mt_eq_2", "topicId": "math_eq", "examType": "OGE", "text": "Решите неравенство 2x + 3 > 11. Укажите наименьшее целое решение.", "imageUrl": null, "optionIds": ["a","b","c","d"], "optionTexts": ["3","4","5","6"], "correctOptionId": "c", "correctShortAnswer": null, "explanation": "2x > 8 → x > 4. Наименьшее целое число, большее 4, — это 5.", "difficulty": 2 },
  { "id": "mt_eq_3", "topicId": "math_eq", "examType": "OGE", "text": "Решите уравнение x² − 9 = 0. Укажите больший корень.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "3", "explanation": "x² = 9 → x = ±3. Больший корень — 3.", "difficulty": 2 },

  { "id": "mt_seq_1", "topicId": "math_seq", "examType": "OGE", "text": "Арифметическая прогрессия задана условиями a₁ = 5, d = 3. Найдите a₁₀.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "32", "explanation": "aₙ = a₁ + (n−1)d = 5 + 9×3 = 32.", "difficulty": 2 },
  { "id": "mt_seq_2", "topicId": "math_seq", "examType": "OGE", "text": "Найдите сумму первых пяти членов геометрической прогрессии 2, 4, 8, 16, ...", "imageUrl": null, "optionIds": ["a","b","c","d"], "optionTexts": ["30","62","64","31"], "correctOptionId": "b", "correctShortAnswer": null, "explanation": "2+4+8+16+32 = 62.", "difficulty": 2 },
  { "id": "mt_seq_3", "topicId": "math_seq", "examType": "OGE", "text": "Найдите d арифметической прогрессии, если a₁ = 2, a₅ = 18.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "4", "explanation": "a₅ = a₁ + 4d → 18 = 2 + 4d → d = 4.", "difficulty": 2 },

  { "id": "mt_word_1", "topicId": "math_word", "examType": "OGE", "text": "Велосипедист проехал 60 км за 4 часа. С какой средней скоростью он двигался?", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "15", "explanation": "60 / 4 = 15 км/ч.", "difficulty": 1 },
  { "id": "mt_word_2", "topicId": "math_word", "examType": "OGE", "text": "Первый рабочий выполняет заказ за 6 дней, второй — за 12 дней. За сколько дней они выполнят заказ вместе?", "imageUrl": null, "optionIds": ["a","b","c","d"], "optionTexts": ["3","4","5","6"], "correctOptionId": "b", "correctShortAnswer": null, "explanation": "1/6 + 1/12 = 1/4 в день. Время = 4 дня.", "difficulty": 2 },
  { "id": "mt_word_3", "topicId": "math_word", "examType": "OGE", "text": "Поезд прошёл 350 км за 5 часов, а затем ещё 150 км за 3 часа. Найдите среднюю скорость поезда за всё время.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "62.5", "explanation": "Общий путь 500 км, время 8 часов. 500/8 = 62.5 км/ч.", "difficulty": 2 },

  { "id": "mt_func_1", "topicId": "math_func", "examType": "OGE", "text": "График функции y = 2x − 3 пересекает ось Oy в точке с координатой y, равной:", "imageUrl": null, "optionIds": ["a","b","c","d"], "optionTexts": ["-3","0","2","3"], "correctOptionId": "a", "correctShortAnswer": null, "explanation": "При x = 0 значение y = 2×0 − 3 = −3.", "difficulty": 1 },
  { "id": "mt_func_2", "topicId": "math_func", "examType": "OGE", "text": "Найдите значение функции y = x² − 4x + 3 при x = 1.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "0", "explanation": "1 − 4 + 3 = 0.", "difficulty": 1 },
  { "id": "mt_func_3", "topicId": "math_func", "examType": "OGE", "text": "При каком значении x функция y = 5x − 10 обращается в ноль?", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "2", "explanation": "5x − 10 = 0 → x = 2.", "difficulty": 1 },

  { "id": "mt_geo_1", "topicId": "math_geo", "examType": "OGE", "text": "Сумма углов треугольника равна:", "imageUrl": null, "optionIds": ["a","b","c"], "optionTexts": ["90°","180°","360°"], "correctOptionId": "b", "correctShortAnswer": null, "explanation": "Сумма внутренних углов любого треугольника на плоскости всегда равна 180°.", "difficulty": 1 },
  { "id": "mt_geo_2", "topicId": "math_geo", "examType": "OGE", "text": "Катеты прямоугольного треугольника равны 6 и 8. Найдите гипотенузу.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "10", "explanation": "По теореме Пифагора: √(36+64) = 10.", "difficulty": 1 },
  { "id": "mt_geo_3", "topicId": "math_geo", "examType": "OGE", "text": "Найдите площадь прямоугольника со сторонами 7 см и 5 см.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "35", "explanation": "Площадь прямоугольника = произведение сторон: 7×5 = 35 см².", "difficulty": 1 },

  { "id": "mt_prob_1", "topicId": "math_prob", "examType": "OGE", "text": "В классе 25 учеников, среди них два близнеца. Класс случайным образом делят на две группы по 12 и 13 человек. Найдите вероятность того, что близнецы окажутся в одной группе.", "imageUrl": null, "optionIds": ["a","b","c","d"], "optionTexts": ["0.46","0.5","0.52","0.48"], "correctOptionId": "a", "correctShortAnswer": null, "explanation": "P = (12/25)×(11/24) + (13/25)×(12/24) ≈ 0.46.", "difficulty": 2 },
  { "id": "mt_prob_2", "topicId": "math_prob", "examType": "OGE", "text": "В коробке 4 красных и 6 синих шаров. Найдите вероятность того, что наугад вынутый шар красный.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "0.4", "explanation": "P = 4 / (4+6) = 0.4.", "difficulty": 1 },
  { "id": "mt_prob_3", "topicId": "math_prob", "examType": "OGE", "text": "Монету бросают дважды. Найдите вероятность того, что оба раза выпадет орёл.", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "0.25", "explanation": "P = 0.5 × 0.5 = 0.25.", "difficulty": 2 },

  { "id": "mt_real_1", "topicId": "math_real", "examType": "OGE", "text": "Тариф на такси: посадка 100 руб. + 20 руб. за км. Сколько будет стоить поездка на 12 км?", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "340", "explanation": "100 + 20×12 = 340 рублей.", "difficulty": 1 },
  { "id": "mt_real_2", "topicId": "math_real", "examType": "OGE", "text": "Комната имеет форму прямоугольника 4 м × 5 м. Сколько потребуется банок краски, если одной хватает на 10 м²?", "imageUrl": null, "optionIds": ["a","b","c","d"], "optionTexts": ["1","2","3","4"], "correctOptionId": "b", "correctShortAnswer": null, "explanation": "Площадь пола 4×5=20 м². 20 / 10 = 2 банки.", "difficulty": 1 },
  { "id": "mt_real_3", "topicId": "math_real", "examType": "OGE", "text": "Тариф на мобильную связь: 300 руб. абонплата + 3 руб. за минуту сверх 200 минут. Сколько заплатит абонент при 250 минутах разговора?", "imageUrl": null, "optionIds": [], "optionTexts": [], "correctOptionId": null, "correctShortAnswer": "450", "explanation": "300 + (250−200)×3 = 450 рублей.", "difficulty": 2 }
